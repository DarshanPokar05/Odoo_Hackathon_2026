# ==========================================
# AssetFlow Environment Configuration
# ==========================================
# Copy this file to .env in root or backend/frontend directories

# --- BACKEND DATABASE CONFIGURATION ---
# Direct PostgreSQL connection string (Supabase Direct URL or local Postgres instance)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:5432/assetflow

# --- BACKEND SERVER CONFIGURATION ---
PORT=5000
FRONTEND_ORIGIN=http://localhost:5173
NODE_ENV=development

# --- AUTHENTICATION & JWT CONFIGURATION ---
JWT_SECRET=super_secret_jwt_key_change_in_production_assetflow_2026
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=super_secret_refresh_key_change_in_production_assetflow_2026
JWT_REFRESH_EXPIRES_IN=7d

# --- FRONTEND API CONFIGURATION ---
VITE_API_URL=http://localhost:5000/api
